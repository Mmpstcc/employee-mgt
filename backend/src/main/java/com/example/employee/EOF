package com.example.employee.controller;
import com.example.employee.model.Performance;
import com.example.employee.service.PerformanceService;
import io.swagger.v3.oas.annotations.*;
import io.swagger.v3.oas.annotations.tags.Tag;
import lombok.RequiredArgsConstructor;
import org.springframework.http.*;
import org.springframework.web.bind.annotation.*;
import java.util.*;
@RestController
@RequestMapping("/api/performance")
@CrossOrigin(origins = "*")
@RequiredArgsConstructor
@Tag(name = "Performance Management", description = "APIs for performance reviews")
public class PerformanceController {
    private final PerformanceService service;

    @PostMapping
    @Operation(summary = "Create performance review")
    public ResponseEntity<Performance> create(@RequestBody Performance p){
        return ResponseEntity.status(HttpStatus.CREATED).body(service.createReview(p));
    }

    @PutMapping("/{id}")
    @Operation(summary = "Update performance review")
    public ResponseEntity<Performance> update(@PathVariable String id,@RequestBody Performance p){
        return ResponseEntity.ok(service.updateReview(id,p));
    }

    @GetMapping("/employee/{empId}")
    @Operation(summary = "Get reviews by employee")
    public ResponseEntity<List<Performance>> getByEmployee(@PathVariable String empId){
        return ResponseEntity.ok(service.getByEmployee(empId));
    }

    @GetMapping("/employee/{empId}/summary")
    @Operation(summary = "Get employee performance summary")
    public ResponseEntity<Map<String,Object>> getSummary(@PathVariable String empId){
        return ResponseEntity.ok(service.getEmployeeSummary(empId));
    }

    @GetMapping("/year/{year}")
    @Operation(summary = "Get reviews by year")
    public ResponseEntity<List<Performance>> getByYear(@PathVariable int year){
        return ResponseEntity.ok(service.getByYear(year));
    }

    @GetMapping
    @Operation(summary = "Get all reviews")
    public ResponseEntity<List<Performance>> getAll(){
        return ResponseEntity.ok(service.getAll());
    }

    @DeleteMapping("/{id}")
    @Operation(summary = "Delete review")
    public ResponseEntity<Map<String,String>> delete(@PathVariable String id){
        service.delete(id);
        return ResponseEntity.ok(Map.of("message","Review deleted"));
    }

    @ExceptionHandler(RuntimeException.class)
    public ResponseEntity<Map<String,String>> handleError(RuntimeException e){
        return ResponseEntity.badRequest().body(Map.of("error",e.getMessage()));
    }
}

