

package com.example.employee.controller;
import com.example.employee.model.Attendance;
import com.example.employee.service.AttendanceService;
import io.swagger.v3.oas.annotations.*;
import io.swagger.v3.oas.annotations.tags.Tag;
import lombok.RequiredArgsConstructor;
import org.springframework.format.annotation.DateTimeFormat;
import org.springframework.http.*;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDate;
import java.util.*;
@RestController
@RequestMapping("/api/attendance")
@CrossOrigin(origins = "*")
@RequiredArgsConstructor
@Tag(name = "Attendance Management", description = "APIs for tracking attendance")
public class AttendanceController {
    private final AttendanceService service;

    @PostMapping("/checkin/{employeeId}")
    @Operation(summary = "Employee check in")
    public ResponseEntity<Attendance> checkIn(@PathVariable String employeeId){
        return ResponseEntity.status(HttpStatus.CREATED).body(service.checkIn(employeeId));
    }

    @PutMapping("/checkout/{employeeId}")
    @Operation(summary = "Employee check out")
    public ResponseEntity<Attendance> checkOut(@PathVariable String employeeId){
        return ResponseEntity.ok(service.checkOut(employeeId));
    }

    @GetMapping("/employee/{empId}")
    @Operation(summary = "Get attendance by employee")
    public ResponseEntity<List<Attendance>> getByEmployee(@PathVariable String empId){
        return ResponseEntity.ok(service.getByEmployee(empId));
    }

    @GetMapping("/date/{date}")
    @Operation(summary = "Get attendance by date")
    public ResponseEntity<List<Attendance>> getByDate(
            @PathVariable @DateTimeFormat(iso=DateTimeFormat.ISO.DATE) LocalDate date){
        return ResponseEntity.ok(service.getByDate(date));
    }

    @GetMapping("/report/{empId}")
    @Operation(summary = "Get monthly attendance report")
    public ResponseEntity<Map<String,Object>> getMonthlyReport(
            @PathVariable String empId,
            @RequestParam int month,
            @RequestParam int year){
        return ResponseEntity.ok(service.getMonthlyReport(empId,month,year));
    }

    @PostMapping("/absent/{employeeId}")
    @Operation(summary = "Mark employee as absent")
    public ResponseEntity<Attendance> markAbsent(
            @PathVariable String employeeId,
            @RequestParam @DateTimeFormat(iso=DateTimeFormat.ISO.DATE) LocalDate date,
            @RequestParam(required=false,defaultValue="") String remarks){
        return ResponseEntity.ok(service.markAbsent(employeeId,date,remarks));
    }

    @ExceptionHandler(RuntimeException.class)
    public ResponseEntity<Map<String,String>> handleError(RuntimeException e){
        return ResponseEntity.badRequest().body(Map.of("error",e.getMessage()));
    }
}
